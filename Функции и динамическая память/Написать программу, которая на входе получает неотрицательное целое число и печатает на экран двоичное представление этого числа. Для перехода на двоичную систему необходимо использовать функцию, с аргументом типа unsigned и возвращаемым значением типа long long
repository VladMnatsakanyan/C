#include <stdio.h>

long long erkuakan_nerkayacum(unsigned n) {
    long long erkuakan = 0;
    long long dirq = 1;
    if(n == 0) {
        return 0;
    }
    while (n > 0) {
        erkuakan = erkuakan + (n % 2) * dirq;
        dirq = dirq * 10;
        n = n / 2;
    }
    return erkuakan;
}
int main(void)
{
    unsigned x;
    scanf("%u", &x);
    long long ardyunq = erkuakan_nerkayacum(x);
    printf("%lld", ardyunq);
    return 0;
}
