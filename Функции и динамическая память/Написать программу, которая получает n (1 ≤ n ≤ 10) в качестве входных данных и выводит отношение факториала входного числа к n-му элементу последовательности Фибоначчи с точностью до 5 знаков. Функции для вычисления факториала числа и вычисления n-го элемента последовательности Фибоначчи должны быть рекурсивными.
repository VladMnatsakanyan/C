#include <stdio.h>

double factorial (int n) {
    if(n == 1 || n == 0) {
        return 1;
    }
    return n * factorial(n-1); 
}
double fib(int n) {
    if(n == 0) {
        return 0;
    } 
    if(n == 1) {
        return 1;
    }
    return fib(n-1) + fib(n-2);
}
int main(void)
{
    int x;
    scanf("%d", &x);
    double ardyunq = factorial(x) / fib(x);
    printf("%.5lf", ardyunq);
    return 0;
}
