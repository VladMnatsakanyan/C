#include <stdio.h>

int parz_tver(int x) {
    if(x <= 1) {
        return 0;
    } 
    for(int i = 2; i * i <= x; i++) {
        if(x % i == 0) {
            return 0;
        }
    }
    return 1;
}
int main(void)
{
    int x;
    scanf("%d", &x);
    int parz_tiv = parz_tver(x);
    if (parz_tiv) {
        printf("YES");
    } else {
        printf("NO");
    }

    return 0;
}
