#include <stdio.h>
#include <string.h>

int main(void)
{
    char word[20];
    char word2[20];
    int count[127] = {0};
    int count2[127] = {0};
    scanf("%s", word);
    scanf("%s", word2);
    if(strlen(word) != strlen(word2)) {
        printf("NO");
        return 0;
    }
    for(int i = 0; i < strlen(word); i++) {
        count[(unsigned char)word[i]]++;
        count2[(unsigned char)word2[i]]++;
    }
    for(int i = 0; i < 127; i++) {
        if(count[i] != count2[i]) {
            printf("NO");
            return 0;
        }
    }
    printf("YES");
    return 0;
}
