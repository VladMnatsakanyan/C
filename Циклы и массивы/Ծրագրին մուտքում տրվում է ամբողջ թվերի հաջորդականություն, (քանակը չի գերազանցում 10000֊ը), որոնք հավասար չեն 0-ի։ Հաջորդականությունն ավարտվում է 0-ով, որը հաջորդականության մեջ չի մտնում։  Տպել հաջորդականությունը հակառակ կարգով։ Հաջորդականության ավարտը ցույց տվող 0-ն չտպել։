#include <stdio.h>
int main(void)
{
    int arr[10000];
    int size = 0;
    int x;
    while (1) {
        scanf("%d", &x);
        if (x == 0)
            break;
        arr[size] = x;
        size++;
    }
    for (int i = size - 1; i >= 0; i--) {
        printf("%d ", arr[i]);
    }
    return 0;
}
