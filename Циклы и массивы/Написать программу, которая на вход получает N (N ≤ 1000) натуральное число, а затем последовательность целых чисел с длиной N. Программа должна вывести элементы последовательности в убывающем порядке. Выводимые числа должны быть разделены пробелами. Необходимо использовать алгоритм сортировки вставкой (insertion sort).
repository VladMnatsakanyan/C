#include <stdio.h>

int main(void)
{
    int N;
    scanf("%d", &N);
    int arr[1000];
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }
    int key;
    int j;
    for(int i = 0; i < N; i++) {
        key = arr[i];
        j = i-1;
        while(j >= 0 && arr[j] < key) {
            arr[j+1] = arr[j];
            j = j - 1;
        }
        arr[j+1] = key;
    }
    
    for(int k = 0; k < N; k++) {
            printf("%d ", arr[k]);
    }
    return 0;
}
