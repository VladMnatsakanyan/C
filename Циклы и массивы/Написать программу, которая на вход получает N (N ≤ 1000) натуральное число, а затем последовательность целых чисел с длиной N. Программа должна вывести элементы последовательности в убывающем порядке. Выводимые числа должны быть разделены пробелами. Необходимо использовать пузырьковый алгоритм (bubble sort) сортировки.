#include <stdio.h>

int main(void)
{
    int N;
    scanf("%d", &N);
    int arr[1000];
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }
    int swapped;
    for(int i = 0; i < N-1; i++) {
        swapped = 0;
        for(int j = 0; j < N-i-1; j++) {
            if(arr[j] < arr[j+1]) {
                int temp = arr[j+1];
                arr[j+1] = arr[j];
                arr[j] = temp;
                swapped = 1;
            }
        }
        if(swapped == 0) {
            break;
        }
    }
    for(int k = 0; k < N; k++) {
            printf("%d ", arr[k]);
    }
    return 0;
}
