#include <stdio.h>

int main(void)
{
    int arr[10];
    int arr2[10];
    int nuyn;
    for(int i = 0; i < 10; i++) {
        scanf("%d", &arr[i]);
    }
    for(int j = 0; j < 10; j++) {
        scanf("%d", &arr2[j]);
    }
    for(int i = 0; i < 10; i++) {
        nuyn = 0;
        for(int j = 0; j < 10; j++) {
            if(arr[i] == arr2[j]) {
                nuyn = 1;
                break;
            }
        }
        if(!(nuyn)) {
            printf("%d ", arr[i]);
        }
    }
    return 0;
}
