#include <stdio.h>

int main(void)
{
    int N;
    scanf("%d", &N);
    int arr[1000];
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }
    int count = 0;
    for(int i = 0; i < N; i++) {
        if(arr[i] != arr[N-1]) {
            count++;
        }
    }
    printf("%d", count);

    return 0;
}
