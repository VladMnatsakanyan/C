#include <stdio.h>

int main(void)
{
    int N;
    scanf("%d", &N);
    int arr[10000];
    int calculator[10001] = {0};
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
        if((arr[i] < 1) || (arr[i] > N)) {
            printf("No");
            return 0;
        }
        calculator[arr[i]]++;
    }
    for(int i = 1; i <=N; i++) {
        if(calculator[i] != 1) {
            printf("No");
            return 0;
        }
    }
    printf("Yes");
    return 0;
}
