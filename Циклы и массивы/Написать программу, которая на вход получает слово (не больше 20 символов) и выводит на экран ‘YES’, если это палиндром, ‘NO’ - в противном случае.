#include <stdio.h>
#include <string.h>

int main(void)
{
    char S1[20];
    scanf("%s", S1);
    int palindrom = 1;
    for(int i = 0; i < strlen(S1) / 2; i++) {
        if(S1[i] != S1[strlen(S1) - 1 - i]) {
            palindrom = 0;
            break;
        }
    }
    if(palindrom == 1) {
        printf("YES");
    } else {
        printf("NO");
    }
    return 0;
}
