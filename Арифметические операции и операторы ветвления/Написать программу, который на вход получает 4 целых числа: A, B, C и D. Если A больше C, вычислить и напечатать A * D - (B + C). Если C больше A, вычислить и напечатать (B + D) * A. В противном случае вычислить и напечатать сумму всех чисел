#include <stdio.h>

int main(void)
{
    int a;
    int b;
    int c;
    int d;
    scanf("%d", &a);
    scanf("%d", &b);
    scanf("%d", &c);
    scanf("%d", &d);
    int x = ((a*d)-(b+c));
    int y = ((b+d)*a);
    if(a>c) {
        printf("%d", x);
    } else if(c>a) {
        printf("%d", y);
    } else {
        printf("%d", a+b+c+d);
    }

    return 0;
}
